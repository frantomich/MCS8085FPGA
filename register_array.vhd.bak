LIBRARY IEEE;
USE IEEE.STD_LOGIC_1164.ALL;
USE IEEE.NUMERIC_STD.ALL;

ENTITY register_array IS

	PORT(
	
		clk, rst: IN STD_LOGIC;
		reg_sel_rd: IN STD_LOGIC_VECTOR(2 DOWNTO 0);
		reg_data_out: OUT STD_LOGIC_VECTOR(7 DOWNTO 0);
		reg_sel_wr: IN STD_LOGIC_VECTOR(2 DOWNTO 0);
		reg_sel_en: IN STD_LOGIC;
		reg_data_in: IN STD_LOGIC_VECTOR(7 DOWNTO 0);
		rp_sel: IN STD_LOGIC_VECTOR(1 DOWNTO 0);
		rp_wr_en: IN STD_LOGIC;
		rp_data_in: IN STD_LOGIC_VECTOR(15 DOWNTO 0);
		rp_data_out: OUT STD_LOGIC_VECTOR(15 DOWNTO 0)
		
	)
	
END register_array;

ARCHITECTURE register_array_logic OF register_array IS

	SIGNAL reg_b, reg_c, reg_d, reg_e, reg_h, reg_l: STD_LOGIC_VECTOR(7 DOWNTO 0);
	SIGNAL reg_sp: STD_LOGIC_VECTOR(15 DOWNTO 0);
	
BEGIN

	PROCESS(reg_sel_rd, reg_b, reg_c, reg_d, reg_e, reg_h, reg_l)
	BEGIN
		CASE reg_sel_rd IS
		WHEN "000" => reg_data_out <= reg_b;
		WHEN "001" => reg_data_out <= reg_c;
		WHEN "010" => reg_data_out <= reg_d;
		WHEN "011" => reg_data_out <= reg_e;
		WHEN "100" => reg_data_out <= reg_h;
		WHEN "101" => reg_data_out <= reg_l;
		WHEN OTHERS => reg_data_out <= (OTHERS => '0');